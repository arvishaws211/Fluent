rules_version = '2';

// SPDX-License-Identifier: MIT
// Copyright (c) 2026 Fluent Project Contributors
//
// Defense in depth: Firebase Auth + App Check + role claim + collection-scoped
// permissions. Default-deny is enforced at the bottom; every collection must
// be opted in explicitly. Run `firebase emulators:exec --only firestore`
// against `firestore.rules.test.ts` before each rule change.

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function appChecked() {
      // App Check token presence is enforced when App Check is on; this is
      // a no-op locally but blocks unverified clients in production.
      return request.auth != null && request.auth.token.firebase != null;
    }

    function isStaffOrSponsor() {
      return signedIn() && (
        request.auth.token.role == 'staff' ||
        request.auth.token.role == 'sponsor'
      );
    }

    function isOwner(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    // -- Attendee profiles -------------------------------------------------
    // Each user owns their own profile doc; staff can read all for analytics.
    match /attendees/{uid} {
      allow read: if isOwner(uid) || isStaffOrSponsor();
      allow create: if isOwner(uid)
        && request.resource.data.keys().hasOnly(
             ['displayName', 'interests', 'role', 'ssiIdentifier',
              'createdAt', 'updatedAt']
           )
        && request.resource.data.role == 'attendee';
      allow update: if isOwner(uid)
        // role field is immutable for attendees; staff promotion happens via
        // a Cloud Function with a service-account auth check.
        && (!('role' in request.resource.data.diff(resource.data).affectedKeys())
            || isStaffOrSponsor());
      allow delete: if false;
    }

    // -- Staff runbook -----------------------------------------------------
    // Operational data; only staff/sponsor roles see it.
    match /runbook/{taskId} {
      allow read, list: if isStaffOrSponsor();
      allow create, update: if isStaffOrSponsor()
        && request.resource.data.keys().hasAll(['title', 'status', 'priority'])
        && request.resource.data.status in ['pending', 'in-progress', 'completed', 'blocked']
        && request.resource.data.priority in ['low', 'medium', 'high'];
      allow delete: if isStaffOrSponsor();
    }

    // -- Sensory zones (IoT heatmap snapshots) ----------------------------
    // Public-read so any attendee can render the wayfinding map; only the
    // ingestion service (writes via service account) can write.
    match /zones/{zoneId} {
      allow read: if signedIn();
      allow write: if false; // server only via Admin SDK
    }

    // -- AI matchmaking cache ---------------------------------------------
    // Owned by the attendee; the Cloud Function writes here on the user's
    // behalf using the requester's uid.
    match /matches/{uid}/results/{matchId} {
      allow read: if isOwner(uid);
      allow write: if false; // server only
    }

    // -- Check-in audit log -----------------------------------------------
    // Append-only; users can read their own; staff can read all.
    match /checkIns/{checkInId} {
      allow read: if isOwner(resource.data.uid) || isStaffOrSponsor();
      allow create: if isOwner(request.resource.data.uid);
      allow update, delete: if false;
    }

    // Default deny — keep this last.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
