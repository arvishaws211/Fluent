{
  "$schema": "./node_modules/@angular/service-worker/config/schema.json",
  "index": "/index.html",
  "navigationUrls": [
    "/**",
    "!/**/*.*",
    "!/**/*__*",
    "!/**/*__*/**",
    "!/__/**"
  ],
  "assetGroups": [
    {
      "name": "app",
      "installMode": "prefetch",
      "resources": {
        "files": [
          "/favicon.ico",
          "/index.html",
          "/manifest.webmanifest",
          "/offline.html",
          "/*.css",
          "/*.js"
        ]
      }
    },
    {
      "name": "assets",
      "installMode": "lazy",
      "updateMode": "prefetch",
      "resources": {
        "files": [
          "/assets/**",
          "/icons/**",
          "/*.(svg|cur|jpg|jpeg|png|apng|webp|avif|gif|otf|ttf|woff|woff2)"
        ]
      }
    }
  ],
  "dataGroups": [
    {
      "name": "firestore-runbook",
      "urls": ["https://firestore.googleapis.com/**"],
      "cacheConfig": {
        "strategy": "freshness",
        "maxSize": 100,
        "maxAge": "1h",
        "timeout": "3s"
      }
    },
    {
      "name": "ai-functions",
      "urls": ["https://*-*.cloudfunctions.net/**", "https://*.run.app/**"],
      "cacheConfig": {
        "strategy": "freshness",
        "maxSize": 50,
        "maxAge": "10m",
        "timeout": "5s"
      }
    },
    {
      "name": "google-fonts",
      "urls": ["https://fonts.googleapis.com/**", "https://fonts.gstatic.com/**"],
      "cacheConfig": {
        "strategy": "performance",
        "maxSize": 30,
        "maxAge": "30d"
      }
    }
  ]
}
