#
# Copy this file to `.env` (gitignored) and paste REAL values from the
# consoles linked below, then run `npm run build` (the prebuild hook runs
# `scripts/setup-env.mjs` and regenerates src/environments/environment.*.ts).
#
# If you see `auth/api-error` or `recaptcha/sitekey-missing` in the browser
# console, at least one value below is wrong, empty, or still a placeholder.

# -----------------------------------------------------------------------------
# Firebase web config
#   Where to find: https://console.firebase.google.com/
#     -> your project -> Project settings -> General
#     -> scroll to "Your apps" -> your web app
#     -> "SDK setup and configuration" -> "Config" tab
#   Copy each value from the `firebaseConfig` object shown there.
# -----------------------------------------------------------------------------
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=
FIREBASE_SENDER_ID=
FIREBASE_APP_ID=
FIREBASE_MEASUREMENT_ID=

# -----------------------------------------------------------------------------
# Google Maps Platform (browser key)
#   Where to find: https://console.cloud.google.com/google/maps-apis/credentials
#     -> select your project -> "Create credentials" -> API key
#   IMPORTANT: restrict it to HTTP referrers (your domain + localhost:4200)
#   AND restrict it to Maps JavaScript API + Maps Embed API only. An
#   unrestricted key WILL be scraped from the bundle and used for abuse.
# -----------------------------------------------------------------------------
GOOGLE_MAPS_API_KEY=

# Cloud-based Map ID (required for AdvancedMarkerElement).
#   Where to find: https://console.cloud.google.com/google/maps-apis/studio/maps
#     -> "Create new Map ID" -> Map type: "JavaScript" -> save the ID
#   Never use DEMO_MAP_ID in production; it has an "unofficial" banner.
GOOGLE_MAPS_MAP_ID=

# -----------------------------------------------------------------------------
# Firebase App Check (reCAPTCHA Enterprise)
#   Where to find SITE KEY:
#     https://console.cloud.google.com/security/recaptcha
#     -> same project as Firebase -> "Create key"
#     -> Platform type "Website" -> add your domain + localhost
#     -> copy the "Site key" (NOT the API key)
#   Then in Firebase Console -> App Check -> your web app
#     -> pick "reCAPTCHA Enterprise" -> paste the site key
#   Do NOT enable enforcement in the Firebase console until you verify the
#   key works end-to-end; otherwise all Firebase requests will start failing
#   with auth/api-error immediately.
# -----------------------------------------------------------------------------
APP_CHECK_SITE_KEY=

# -----------------------------------------------------------------------------
# GCP region for Cloud Run + Cloud Functions. Keep these aligned so clients
# don't pay cross-region egress.
# -----------------------------------------------------------------------------
GCP_REGION=us-central1

# -----------------------------------------------------------------------------
# Use Firebase Local Emulator Suite for offline dev (true/false).
# When true:
#   - App Check falls back to a local debug token automatically.
#   - Auth/Firestore/Functions connect to 127.0.0.1 instead of the cloud.
# -----------------------------------------------------------------------------
USE_EMULATORS=false
