#
# Copy this file to `.env` (gitignored) and fill real values, then run
# `npm run setup:env` to materialize the Angular environment files.
# In CI, populate these from your secret manager before running the build.

# Firebase web config (Firebase Console -> Project Settings -> General -> SDK setup)
FIREBASE_API_KEY=your-firebase-web-api-key
FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
FIREBASE_PROJECT_ID=your-project
FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
FIREBASE_SENDER_ID=000000000000
FIREBASE_APP_ID=1:000000000000:web:abc123
FIREBASE_MEASUREMENT_ID=G-XXXXXXX

# Google Maps Platform (Cloud Console -> APIs & Services -> Credentials)
# IMPORTANT: this key MUST have HTTP referrer restrictions configured.
GOOGLE_MAPS_API_KEY=your-maps-key
# Cloud-based Map ID (Cloud Console -> Google Maps Platform -> Map Styles)
# Required for AdvancedMarkerElement; do NOT use 'DEMO_MAP_ID' in production.
GOOGLE_MAPS_MAP_ID=your-cloud-map-id

# Firebase App Check (Firebase Console -> App Check -> reCAPTCHA Enterprise)
APP_CHECK_SITE_KEY=your-recaptcha-enterprise-site-key

# GCP region (Cloud Run + Cloud Functions); keep matched.
GCP_REGION=us-central1

# Use Firebase Local Emulator Suite for offline dev (true/false).
USE_EMULATORS=false
